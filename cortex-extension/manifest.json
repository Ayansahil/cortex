{
  "manifest_version": 3,
  "name": "Cortex Saver",
  "version": "1.0",
  "description": "Save anything to Cortex — your second brain",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://cortex-u1lk.onrender.com/*"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Cortex",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}